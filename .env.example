# Portfolio Backend Environment Variables

# Server Configuration
PORT=3004
NODE_ENV=development

# Gmail email sending. Use a Gmail app password, not your normal password.
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-gmail-app-password

# Where portfolio contact messages should be delivered.
CONTACT_TO=srinuabothula14@gmail.com

# Comma-separated frontend URLs allowed to call the API in production.
CORS_ORIGINS=https://your-portfolio.netlify.app,https://your-portfolio.vercel.app
